{
  "name": "gsd-issues",
  "version": "0.1.0",
  "description": "Issue provider abstraction for GSD — GitHub and GitLab via CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "gsd",
    "pi",
    "pi-extension",
    "github",
    "gitlab",
    "issues",
    "issue-tracker"
  ],
  "license": "MIT",
  "author": "GSD Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/gsd-tools/gsd-issues.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  }
}
